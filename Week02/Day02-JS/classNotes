<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JavaScript Array Demo</title>
</head>
<body>
    <h1>JavaScript Array Demo</h1>
    <p id="demo"></p>
 
    <script>
       
        //Array is javascript are objects that can store multiple values in a single variable.
        // They are used to store a list of items and can be accessed by their index.
        //  Arrays can hold any type of data, including numbers, strings, and even other arrays.
        // They are a fundamental part of JavaScript and are widely used in web development for tasks
        // such as storing data, manipulating lists, and creating dynamic content.
        //Arrays are resizable, meaning you can add or remove elements from them as needed.
        //array are zero index based
 
        //Shallow copy vs Deep copy
        //A shallow copy of an array creates a new array that references the same elements as the
        // original array. This means that if you modify an element in the shallow copy, it will also affect the original array.
        //A deep copy of an array creates a new array with new elements that are copies of
        // the original elements. This means that if you modify an element in the deep copy,
        // it will not affect the original array.
 
        //array using literal syntax
        const fruits = ["Apple", "Banana", "Cherry", "Date", "Elderberry", "Fig", "Grape", "Honeydew", "Kiwi", "Lemon"];
        document.getElementById("demo").innerHTML = fruits.join(", ");
 
        console.log("Original array:", fruits);
        //length of array
        console.log("Length of array:", fruits.length);
 
        //Accessing array elements
        console.log("First element:", fruits[0]);
        console.log("Last element:", fruits[fruits.length - 1]);
 
        //accessing array elements using for loop
        console.log("Accessing array elements using for loop:");
        for (let i = 0; i < fruits.length; i++) {
            console.log(fruits[i]);
        }
 
        //using forEach method to access array elements
        console.log("Accessing array elements using forEach method:");
        fruits.forEach(function(fruit) {
            console.log(fruit);
        });
 
 
        //using constructor syntax
        const numbers = new Array(1, 2, 3, 4, 5);
        console.log("Numbers array:", numbers);
 
        console.log(`Type of fruits: ${typeof fruits}`);
        console.log(`Type of numbers: ${typeof numbers}`);
 
        //at(0) method to access first element
        //sort method to sort the array
        fruits.sort();
        console.log("Sorted fruits array:", fruits);
 
 
        //to sort numeric array we need to pass a compare function to the sort method
        numbers.sort(function(a, b) {
                return a - b;
            });
        console.log("Sorted numbers array:", numbers);
 
        //to reverse the array
        fruits.reverse();
 
        //toSorted method to sort the array without modifying the original array
        const sortedFruits = fruits.toSorted();
        console.log("Original fruits array after reverse:", fruits);
        console.log("Sorted fruits array using toSorted method:", sortedFruits);
 
        //toReversed method to reverse the array without modifying the original array
        const reversedFruits = fruits.toReversed();
        console.log("Original fruits array after reverse:", fruits);
        console.log("Reversed fruits array using toReversed method:", reversedFruits);
 
        //indexOf method to find the index of an element in the array
        const index = fruits.indexOf("Cherry");
        console.log("Index of Cherry:", index);
 
        //lastIndexOf method to find the last index of an element in the array
        const lastIndex = fruits.lastIndexOf("Cherry");
        console.log("Last index of Cherry:", lastIndex);
 
 
        //shift method to remove the first element of the array
        const firstFruit = fruits.shift();
        console.log("First fruit removed:", firstFruit);    
        console.log("Fruits array after shift:", fruits);
 
        //unshift method to add an element to the beginning of the array
        fruits.unshift("Mango");
        console.log("Fruits array after unshift:", fruits);
 
        //pop method to remove the last element of the array
        const lastFruit = fruits.pop();
        console.log("Last fruit removed:", lastFruit);
        console.log("Fruits array after pop:", fruits);
 
        //push method to add an element to the end of the array
        fruits.push("Pineapple");
        console.log("Fruits array after push:", fruits);
 
        //splice method to add or remove elements from the array
        //to remove elements from the array
        fruits.splice(2, 1); // removes 1 element at index 2
        console.log("Fruits array after splice (removal):", fruits);
        //to add elements to the array
        fruits.splice(2, 0, "Strawberry"); // adds "Strawberry" at index 2 without removing any element
        console.log("Fruits array after splice (addition):", fruits);
 
        //with() method change value of given index  and returns a new array
        const x=[1,2,3,4,5];
        const newX = x.with(2, 10); // changes the value at index 2 to 10 and returns a new array
        console.log("Original array x:", x);    
        console.log("New array newX:", newX);
 
        //slice method to create a new array by slicing the original array
        const slicedFruits = fruits.slice(1, 4); // creates a new array with elements from index 1 to 3
        console.log("Sliced fruits array:", slicedFruits);
 
        //join method to join the elements of the array into a string
        const fruitsString = fruits.join(", ");
        console.log("Fruits array joined into a string:", fruitsString);
 
        //concat method to merge two or more arrays
        const moreFruits = ["Watermelon", "Papaya"];
        const allFruits = fruits.concat(moreFruits);
        console.log("All fruits array after concat:", allFruits);
 
        //flat method to create a new array with all sub-array elements concatenated into it recursively up to the specified depth
        const nestedArray = [1, 2, [3, 4], [5, 6]];
        const flatArray = nestedArray.flat(); // flattens the array by one level
        console.log("Flat array:", flatArray);
 
        //map method to create a new array by applying a function to each element of the original array
        //in short to transform the array
        const upperCaseFruits = fruits.map(function(fruit) {
            return fruit.toUpperCase().concat(" ###");
        });
        console.log("Fruits array after map (toUpperCase) and ###:", upperCaseFruits);
 
        //reduce method to reduce the array to a single value by applying a function to each element of the array
        //reduce takes a callback function and an optional initial value as arguments.
        // The callback function takes four arguments:
        //accumulator: the accumulated value previously returned in the last invocation of the callback,
        //currentValue: the current elem    ent being processed in the array,
 
        const sum = numbers.reduce(function(accumulator, currentValue) {
            return accumulator + currentValue;
        }, 0); // 0 is the initial value for the accumulator
 
 
        //filter method to create a new array with all elements that pass the test implemented by the provided function
        const longFruits = fruits.filter(function(fruit) {
            return fruit.length > 5; // returns true for fruits with length greater than 5
        });
 
 
 
 
 
 
 
    </script>
</body>
 
</html>
 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Set in JavaScript</title>
    <style>
        body{
            margin: 10px;
            padding: 10px;
        }
    </style>
</head>
<body>
    <h1>Set in JavaScript</h1>
    <p>A Set is a collection of unique values. It can store any type of value, whether primitive or object references.</p>
    <p> Added in ES6 (ECMAScript 2015)</p>
    <script>
        // Create a new Set
        const mySet = new Set();
 
        // Add some values to the Set
        mySet.add(1);
        mySet.add(5);
        mySet.add('some text');
        mySet.add({ name: 'John' });
        mySet.add(1); // This will not be added as it's a duplicate
        mySet.add(4).add(5); // mutliple add in one line, 5 will not be added as it's a duplicate
        // Display the contents of the Set
        console.log(mySet); // Output: Set(4) { 1, 5, 'some text', { name: 'John' } }
 
        // Check if a value exists in the Set
        console.log(mySet.has(5)); // Output: true
        console.log(mySet.has(3)); // Output: false
 
        // Get the size of the Set
        console.log(mySet.size); // Output: 4
 
        // Remove a value from the Set
        mySet.delete(5);
        console.log(mySet); // Output: Set(3) { 1, 'some text', { name: 'John' } }
 
        // Clear all values from the Set
        mySet.clear();
        console.log(mySet); // Output: Set(0) {}
 
 
        const mySet2 = new Set([1, 2, 3, 4, 5,2,3,4]); // Initialize a Set with an array (duplicates will be ignored)
        console.log(mySet2); // Output: Set(5) { 1, 2, 3, 4, 5 }
 
        const arrayNum=[101,102,103,104,105,101,102]; // Array with duplicate values
        const mySet3 = new Set(arrayNum); // Initialize a Set with an array
        console.log(mySet3); // Output: Set(5) { 101, 102, 103, 104, 105 }
 
        //add string in set
        const mySet4 = new Set('Hello World'); // Initialize a Set with a string
        console.log(mySet4); // Output: Set(8) { 'H', 'e', 'l', 'o', ' ', 'W', 'r', 'd' }
 
        //has method
        console.log(mySet4.has('H')); // Output: true
        console.log(mySet4.has('h')); // Output: false (case-sensitive)
 
        //iterate over a Set using for...of loop
        for (const item of mySet2)
        {
            console.log(item); // Output: 1, 2, 3, 4, 5 (each on a new line)
        }
 
        //iterate over a Set using forEach method
        mySet2.forEach(item => {
            console.log(item); // Output: 1, 2, 3, 4, 5 (each on a new line)
        });
 
        //set to array
        const mySet5 = new Set([1, 2, 3, 4, 5]);
        const arrayFromSet = Array.from(mySet5); // Convert Set to Array    
        console.log(arrayFromSet); // Output: [1, 2, 3, 4, 5]
 
        //using spread operator to convert Set to Array
        const arrayFromSet2 = [...mySet5]; // Convert Set to Array using spread operator
        console.log(arrayFromSet2); // Output: [1, 2, 3, 4, 5]
 
 
        //weakset
        const weekSet = new WeakSet(); // Initialize a WeakSet with an array of objects
        const obj1 = { name: 'John' };
        const obj2 = { name: 'Jane' };
        weekSet.add(obj1); // Add objects to the WeakSet
        weekSet.add(obj2);
        console.log(weekSet); // Output: WeakSet { <items unknown> }
        console.log(weekSet.has(obj1)); // Output: true
       
 
 
    </script>
   
</body>
</html>
 
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Map in JavaScript</title>
    <body>
        <h1>Map in JavaScript</h1>
        <script>
            //Map is a collection of keyed data items, just like an Object.
            // But the main difference is that Map allows keys of any type.
 
            //Creating a Map
            let myMap = new Map();
 
            //set() method is used to add key-value pairs to the Map
            myMap.set('name', 'John');
            myMap.set('age', 30);  
            myMap.set('city', 'New York');
 
            console.log(myMap);
 
            //get() method is used to retrieve the value associated with a specific key
            console.log(myMap.get('name')); // Output: John
            console.log(myMap.get('age')); // Output: 30
            console.log(myMap.get('city')); // Output: New York
 
            console.log(myMap.get('country')); // Output: undefined (key does not exist)
 
            //has() method is used to check if a specific key exists in the Map
            console.log(myMap.has('name')); // Output: true
 
            //delete() method is used to remove a key-value pair from the Map
            myMap.delete('age');
            console.log(myMap); // Output: Map(2) { 'name' => 'John', 'city' => 'New York' }
 
            //size property is used to get the number of key-value pairs in the Map
            console.log(myMap.size); // Output: 2
             
            myMap["state"] = "California";
            console.log(myMap); // Output: Map(2) { 'name' => 'John', 'city' => 'New York' } state: "California"
            console.log(myMap["state"]); // Output: California
 
            //iterate over the Map using for...of loop
            for (let [key, value] of myMap)
            {
                console.log(`${key}: ${value}`);
            }
 
            //map to array
            let myArray = Array.from(myMap);
            console.log(myArray); // Output: [ [ 'name', 'John' ], [ 'city', 'New York' ] ]
 
            //map to array  using spread operator
            let myArray2 = [...myMap];
            console.log(myArray2); // Output: [ [ 'name', 'John' ], [ 'city', 'New York' ] ]
 
            let productMap = new Map();
            productMap.set('product1', { name: 'Laptop', price: 1000 });
            productMap.set('product2', { name: 'Phone', price: 500 });
            productMap.set('product3', { name: 'Tablet', price: 300 });
            productMap.set('product4', { name: 'Monitor', price: 200 });
 
 
            //iterate over keys using keys() method
            for (let key of productMap.keys())
            {
                console.log(key); // Output: product1, product2, product3, product4
            }
 
            //iterate over values using values() method
            for (let value of productMap.values())
            {
                console.log(value); // Output: { name: 'Laptop', price: 1000 }, { name: 'Phone', price: 500 }, { name: 'Tablet', price: 300 }, { name: 'Monitor', price: 200 }
            }
 
            //iterate over entries using entries() method
            for (let entry of productMap.entries())
            {
                console.log(entry); // Output: [ 'product1', { name: 'Laptop', price: 1000 } ], [ 'product2', { name: 'Phone', price: 500 } ], [ 'product3', { name: 'Tablet', price: 300 } ], [ 'product4', { name: 'Monitor', price: 200 } ]
            }
 
            const inventory = [
                { name: "Laptop", type: "Electronics", price: 1000, quantity: 10 },
                { name: "Phone", type: "Electronics", price: 500, quantity: 20 },
                { name: "Tablet", type: "Electronics", price: 300, quantity: 15 },
                { name: "Monitor", type: "Electronics", price: 200, quantity: 5 },
                { name: "Chair", type: "Furniture", price: 100, quantity: 50 },
                { name: "Sofa", type: "Furniture", price: 500, quantity: 10 },
                { name: "Shirt", type: "Clothing", price: 50, quantity: 100 },
                { name: "Pants", type: "Clothing", price: 80, quantity: 70 },                
                { name: "Shoes", type: "Footwear", price: 120, quantity: 40 }
            ]
 
           //Map.groupBy() static method is used to group the elements of an array based on a specified key
            const groupedByType = Map.groupBy(inventory, item => item.type);
            console.log(groupedByType);
 
 
            //clear() method is used to remove all key-value pairs from the Map
            //myMap.clear();
        </script>
    </body>
 
