//----------------------------------------------------------------------------------
 
//Promise.all() method is used to wait for multiple promises to resolve.
 
//Promise1---pending-----fulfilled state  v1 at t1
//Promise2---pending-----fulfilled state  v2 at t2
//Promise3---pending-----fulfilled state  v3 at t3
//Promise.all([Promise1, Promise2, Promise3])---->fulfilled state [v1, v2, v3] at max
 
//Promise.all() waits for all the input promises to resolve and returns a new promise
//that resolves to an array conatining the results of the input promises.
//example for resolving multiple promises using Promise.all()
 
console.log("Starting to resolve promises...");
const p1 = new Promise((resolve, reject) => {
    setTimeout(() => {
        console.log("Promise 1 resolved");
        resolve("80");
    }, 1000);
});
 
const p2 = new Promise((resolve, reject) => {
    setTimeout(() => {
        console.log("Promise 2 resolved");
        resolve("90");
    }, 2000);
});
 
const p3 = new Promise((resolve, reject) => {
    setTimeout(() => {
        console.log("Promise 3 resolved");
        resolve("100");
    }, 3000);
});
 
Promise.all([p1, p2, p3])
    .then(results => {
        const total= results.reduce((acc, val) => acc + parseInt(val), 0);
        console.log("Total: " + total); // Total: 270
        console.log(results); // ["80", "90", "100"]
    })
    .catch(error => {
        console.log(error); // handling any error that occurs in any of the promises
    }).finally(() => {
        console.log("All promises completed for first all() call"); // this will always be called at the end
    });
 
 
//if any of the input promises reject, the returned promise from Promise.all() will reject with the reason of the first promise that rejected.
//promise1---pending-----rejected state  r1 at t1
//Promise2---pending-----fulfilled state  v2 at t2
//Promise3---pending-----fulfilled state  v3 at t3
//Promise.all([Promise1, Promise2, Promise3])---->rejected state r1 at t1
 
//Rejected promise example for Promise.all()
 
const p4 = new Promise((resolve, reject) => {
    setTimeout(() => {
        console.log("Promise 4 rejected");
        reject("Error in promise 4");
    }, 1000);
});
 
Promise.all([p1, p2, p3, p4])
    .then(results => {
        console.log(results); // this will not be called as p4 rejects
    })
    .catch(error => {
        console.log(`Error occurred: ${error}`); // "Error in promise 4"
    }).finally(() => {
        console.log("All promises completed for second all() call"); // this will always be called at the end
    });
 

