        setTimeout(() => {
            const success = true; // change to false to simulate an error
            if(success) {
                resolve("Operation successful");
            } else {
                reject("Operation failed");
            }
        }, 1000);
    });
 
 
    //to consume a promise, we can use the then() method which
    // takes two arguments: a callback for when the promise is fulfilled
    // and a callback for when the promise is rejected.
 
    myPromise.then(
        result => {
            console.log(result); // "Operation successful"
        },
        error => {
            console.log(error); // "Operation failed"
        }
    );
 
 
