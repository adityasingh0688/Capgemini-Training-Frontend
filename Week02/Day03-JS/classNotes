//Promise Chaining - allows us to chain multiple asynchronous operations together.
 
let p = new Promise((resolve, reject) =>
{
    setTimeout(() =>
    {
        resolve(10);
    }),3*100; //cretaing a promise that resolves with the value 10 after 300ms
});
 
p.then((result) =>
{
    console.log(result); // 10
    return result * 2; // returning a new value to the next then() in the chain
}).then((result) =>
{
    console.log(result); // 20
    return result * 3; // returning a new value to the next then() in the chain
}).then((result) =>
{
    console.log(result); // 60
}).catch((error) =>
{
    console.log(error); // handling any errors that occur in the chain
}).finally(() =>
{
    console.log("Promise chain completed"); // this will always be called at the end of the chain
});
 
